{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PipelineState",
  "description": "State machine for the 3-phase Grand Audit pipeline. Exposed via /api/v1/pipeline/state for the React dashboard.",
  "type": "object",
  "properties": {
    "current_state": {
      "type": "string",
      "enum": [
        "inception",
        "ultra_meta_audit",
        "stage_1_proportions",
        "stage_2_physics",
        "stage_3_printability",
        "stage_4_aesthetics",
        "generating_sim_3mf",
        "ultra_grand_audit",
        "loop_resolution",
        "final_report"
      ]
    },
    "states": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": ["pending", "in_progress", "passed", "failed", "skipped"]
          },
          "score": { "type": ["integer", "null"], "minimum": 0, "maximum": 10 },
          "model_used": { "type": ["string", "null"] },
          "timestamp": { "type": ["string", "null"], "format": "date-time" }
        }
      }
    },
    "routing": {
      "type": "object",
      "properties": {
        "last_edit_type": {
          "type": "string",
          "enum": ["minor", "major"],
          "description": "Minor=stay in Phase 2 loop. Major=force Phase 3 Grand Audit."
        },
        "delta_feedback_pending": { "type": "boolean" },
        "meta_corrections_applied": { "type": "integer" }
      }
    },
    "history": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "state": { "type": "string" },
          "status": { "type": "string" },
          "score": { "type": ["integer", "null"] },
          "model_used": { "type": ["string", "null"] },
          "notes": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" }
        }
      }
    }
  },
  "required": ["current_state", "states", "history"]
}
