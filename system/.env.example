# NL2Bot Environment Configuration
# Copy this file to .env and fill in your values

# Claude API (primary — 3D modeling, planning)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Gemini API (secondary — simpler tasks)
GEMINI_API_KEY=your-gemini-key-here

# GCP
GCP_PROJECT_ID=nl2bot-xxxxxx

# JWT Authentication
JWT_SECRET_KEY=generate-with-openssl-rand-hex-32

# Admin credentials (first-run bootstrap)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Simulation server URL (if running separately)
SIMULATION_SERVER_URL=http://localhost:8100

# Server ports
PLAN_PORT=8000
SIM_PORT=8100

# Cloudflare Access (for setup_cloudflare_access.sh)
# CF_API_TOKEN=your-cloudflare-api-token
# CF_ACCOUNT_ID=your-cloudflare-account-id
