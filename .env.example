# NL2Bot Environment Configuration
# Copy to .env and fill in your values: cp .env.example .env

# LLM API Keys
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
GEMINI_API_KEY=your-gemini-key-here

# GCP (optional — for secret management and backups)
GCP_PROJECT_ID=your-gcp-project-id

# Auth
JWT_SECRET_KEY=generate-with-openssl-rand-hex-32
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-production

# Server binding
PLAN_HOST=0.0.0.0
PLAN_PORT=8000
SIM_HOST=0.0.0.0
SIM_PORT=8100

# Inter-service communication
SIMULATION_SERVER_URL=http://localhost:8100
SIM_API_KEY=generate-with-python-secrets-token_hex-32

# Pipeline settings
MAX_REFINEMENT_ITERATIONS=2

# OpenSCAD (simulation server)
# OPENSCAD_BIN=openscad
# OPENSCAD_TIMEOUT=120
# USE_XVFB=true

# Webots (optional — for physics simulation)
# WEBOTS_HOME=C:\Program Files\Webots
